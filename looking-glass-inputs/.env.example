# Mainnet writes are disabled unless ENABLE_MAINNET_TRANSACTIONS=1.
ETH_RPC_URL=https://mainnet.infura.io/v3/YOUR_INFURA_KEY
ETH_PRIVATE_KEY=YOUR_PRIVATE_KEY

# Optional overrides
CHAIN_ID=1
ENABLE_MAINNET_TRANSACTIONS=0
TO_ADDRESS=
GAS_PRICE_GWEI=5
FLASK_HOST=0.0.0.0
FLASK_PORT=5000
WATCH_DIR=./looking_glass_inputs
PLOT_DIR=./plots
BATCH_SIZE=50
